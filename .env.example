# Jyotish AI — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Telegram Bot (required for bot + scheduler)
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (required for scheduler)
# Get by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=

# Groq API Key (optional — for AI interpretation)
# Get free at https://console.groq.com
GROQ_API_KEY=
