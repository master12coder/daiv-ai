# Jyotish AI — Environment Variables
# Copy to .env: cp .env.example .env

# ── Web App (required for web dashboard) ──
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-secret
SECRET_KEY=generate-with-python-secrets-token-hex-32
DATABASE_URL=sqlite:///data/daivai.db
ALLOWED_EMAILS=
# BYPASS_AUTH=true  # Local dev only, NEVER in production

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LLM (optional) ──
GROQ_API_KEY=
